# docker/.env.test — 테스트 환경 (커밋 OK, 민감정보 없음)
SPRING_PROFILES_ACTIVE=test

# Database
DB_ROOT_PASSWORD=test_root_password
DB_PASSWORD=test_password

# JWT (테스트용)
JWT_SECRET=test-jwt-secret-key-for-ci-testing-padding-32ch!

# OpenAI (테스트에서는 항상 시뮬레이션)
OPENAI_API_KEY=

# Upload
UPLOAD_PATH=/data/uploads

# Redis
REDIS_PASSWORD=test_redis_password
