# docker/.env.dev — 개발 환경 (커밋 OK, 민감정보 없음)
SPRING_PROFILES_ACTIVE=dev

# Database
DB_ROOT_PASSWORD=dev_root_password
DB_PASSWORD=dev_password

# JWT (개발용 — 보안 강도 무관)
JWT_SECRET=dev-jwt-secret-key-for-local-dev-padding-32ch!

# OpenAI (비워두면 시뮬레이션 모드 동작)
OPENAI_API_KEY=

# Upload
UPLOAD_PATH=/data/uploads

# Redis
REDIS_PASSWORD=dev_redis_password
