# docker/.env.prod.example — 프로덕션 환경 템플릿
# 실제 운영 시: cp docker/.env.prod.example docker/.env.prod 후 값 채우기
# .env.prod 는 .gitignore 처리됨 (절대 커밋 금지)

SPRING_PROFILES_ACTIVE=prod

# Database — 충분히 복잡한 비밀번호 사용
DB_ROOT_PASSWORD=CHANGE_ME_ROOT
DB_PASSWORD=CHANGE_ME_DB_PASS

# JWT — 최소 256bit (32자) 이상 랜덤 문자열
# 생성: openssl rand -base64 64
JWT_SECRET=CHANGE_TO_LONG_RANDOM_256BIT_SECRET_STRING

# OpenAI API 키
OPENAI_API_KEY=sk-...

# Upload
UPLOAD_PATH=/data/uploads

# Redis 비밀번호
REDIS_PASSWORD=CHANGE_ME_REDIS_PASS
