# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files (exclude gradle wrapper jar)
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Gradle build output and caches
build/
.gradle/
out/

.vscode/sftp.json

# Spring Boot 환경별 설정 (프로덕션 설정 노출 방지)
application-prod.yml
application-prod.yaml
.env

# Docker 환경변수 (프로덕션 실제값 노출 방지)
docker/.env.prod

# 업로드된 파일
uploads/
uploads-test/

# k8s Secret 파일 (민감정보)
k8s/*secret*.yml
k8s/*secret*.yaml
